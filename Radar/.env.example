# Opportunity Radar — Environment Configuration
# Copy this as .env and adjust values for your setup

# ── LLM Provider ──
# Choose: "ollama" (local) or "anthropic" (cloud)
LLM_PROVIDER=ollama

# ── Ollama Configuration (if using local LLM) ──
# Get key from: https://ollama.ai/ (Ollama is free and runs locally)
# Models: mistral, llama2, neural-chat, openchat, etc.
OLLAMA_API_KEY=your-ollama-key-here
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# ── Anthropic API (if using Claude) ──
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Fetch Intervals (seconds) ──
FETCH_INTERVAL_FILINGS=300        # Corporate filings every 5 min
FETCH_INTERVAL_BULK=120            # Bulk/block deals every 2 min
FETCH_INTERVAL_INSIDER=600         # Insider trading every 10 min
FETCH_INTERVAL_INDICES=60          # Market indices every 1 min

# ── Signal Threshold Tuning ──
SIGNAL_MIN_SCORE=40.0              # Minimum composite score to emit (0-100)
VOLUME_ZSCORE_THRESHOLD=2.0        # Volume z-score threshold for anomaly
NLP_ANOMALY_SIGMA=2.0              # NLP anomaly sigma threshold
INSIDER_MIN_VALUE_CR=0.5           # Min insider trade value in crores
BULK_DEAL_MIN_PCT=0.5              # Min bulk deal % of shares

# ── Server ──
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info                     # debug, info, warning, error

# ── Database ──
DATABASE_URL=sqlite+aiosqlite:///./signals.db

# ── NSE Configuration ──
NSE_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
